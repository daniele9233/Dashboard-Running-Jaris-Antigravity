# ── FRONTEND (Vite) ───────────────────────────────────────────────────────────
# Backend API URL — locale o prod su Render.
VITE_BACKEND_URL=http://localhost:8000

# Mapbox public token (pk.*). Restringerlo per dominio nella dashboard Mapbox.
VITE_MAPBOX_TOKEN=your_mapbox_public_token_here

# Gemini API key (usata client-side per JARVIS via @google/genai).
GEMINI_API_KEY=your_gemini_api_key_here
